{
  "name": "nanoclaudecode",
  "version": "0.1.0",
  "description": "Enterprise AI coding assistant with Nano Claude",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test src/__tests__/**/*.test.ts",
    "test:integration": "bun test src/__tests__/integration/**/*.test.ts",
    "test:e2e": "bun test src/__tests__/e2e/**/*.test.ts",
    "test:coverage": "bun test --coverage",
    "lint": "biome lint src/",
    "format": "biome format src/ --write",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "@modelcontextprotocol/sdk": "^0.7.0",
    "better-sqlite3": "^12.6.2",
    "blessed": "^0.1.81",
    "openai": "^4.67.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
